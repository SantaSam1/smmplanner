# Supabase (REQUIRED)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OAuth Apps - Instagram/Facebook (Meta) (REQUIRED for OAuth)
# Get from: https://developers.facebook.com/
VITE_INSTAGRAM_APP_ID=your-instagram-app-id
VITE_FACEBOOK_APP_ID=your-facebook-app-id

# OAuth Apps - Twitter/X (OPTIONAL)
# Get from: https://developer.twitter.com/
VITE_TWITTER_API_KEY=your-twitter-api-key

# OAuth Apps - LinkedIn (OPTIONAL)
# Get from: https://www.linkedin.com/developers/
VITE_LINKEDIN_APP_ID=your-linkedin-app-id

# OAuth Apps - TikTok (OPTIONAL)
# Get from: https://developers.tiktok.com/
VITE_TIKTOK_CLIENT_KEY=your-tiktok-client-key

# OAuth Apps - YouTube (OPTIONAL)
# Get from: https://console.cloud.google.com/
VITE_YOUTUBE_CLIENT_ID=your-youtube-client-id

# === IMPORTANT ===
# You MUST also add these as Supabase Edge Function Secrets
# Go to: Supabase Dashboard → Functions → oauth-callback → Secrets
# Add:
#   META_APP_ID = your-instagram-app-id (same as VITE_INSTAGRAM_APP_ID)
#   META_APP_SECRET = your-meta-app-secret (from Meta Dashboard)
#   CALLBACK_URL = http://localhost:5173 (for local) or https://yourdomain.com (for production)
